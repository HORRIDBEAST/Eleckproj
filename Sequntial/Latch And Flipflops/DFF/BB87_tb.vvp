E_012B7DF8/1 .event posedge, v012BDA18_0, v012B8F38_0;
E_012B7DF8 .event/or E_012B7DF8/0, E_012B7DF8/1;
    .scope S_011836E0;
T_0 ;
    %wait E_012B7DF8;
    %load/v 8, v012BD9C0_0, 1;
    %inv 8, 1;
    %jmp/0xz  T_0.0, 8;
    %ix/load 0, 1, 0;
    %assign/v0 v011837C0_0, 0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/v 8, v012BDA18_0, 1;
    %jmp/0xz  T_0.2, 8;
    %ix/load 0, 1, 0;
    %assign/v0 v011837C0_0, 0, 1;
    %jmp T_0.3;
T_0.2 ;
    %load/v 8, v01183768_0, 1;
    %ix/load 0, 1, 0;
    %assign/v0 v011837C0_0, 0, 8;
T_0.3 ;
T_0.1 ;
    %jmp T_0;
    .thread T_0;
    .scope S_012B31C8;
T_1 ;
    %delay 5000, 0;
    %load/v 8, v012BDA70_0, 1;
    %inv 8, 1;
    %set/v v012BDA70_0, 8, 1;
    %jmp T_1;
    .thread T_1;
    .scope S_012B31C8;
T_2 ;
