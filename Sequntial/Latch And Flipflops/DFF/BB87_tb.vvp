#! /c/iverilog/bin/vvp
:ivl_version "0.9.7 " "(v0_9_7)";
:vpi_time_precision - 12;
:vpi_module "system";
:vpi_module "v2005_math";
:vpi_module "va_math";
S_012B31C8 .scope module, "dff_PE_ARL_AHS_tb" "dff_PE_ARL_AHS_tb" 2 3;
 .timescale -9 -12;
v012BDA70_0 .var "clk", 0 0;
v012BDAC8_0 .var "d", 0 0;
v012BDB20_0 .net "q", 0 0, v011837C0_0; 1 drivers
