    %vpi_call 2 15 "$dumpvars", 1'sb0, S_012B31C8;
    %vpi_call 2 17 "$monitor", "Time=%0t | d=%b, clk=%b, rst=%b, set=%b -> q=%b", $time, v012BDAC8_0, v012BDA70_0, v012BDB78_0, v012BDBD0_0, v012BDB20_0;
    %set/v v012BDA70_0, 0, 1;
    %set/v v012BDAC8_0, 0, 1;
    %set/v v012BDB78_0, 1, 1;
    %set/v v012BDBD0_0, 0, 1;
    %delay 3000, 0;
    %set/v v012BDB78_0, 0, 1;
    %delay 7000, 0;
    %set/v v012BDB78_0, 1, 1;
    %delay 10000, 0;
    %set/v v012BDAC8_0, 1, 1;
    %delay 10000, 0;
    %set/v v012BDAC8_0, 0, 1;
    %delay 10000, 0;
    %set/v v012BDBD0_0, 1, 1;
    %delay 5000, 0;
    %set/v v012BDBD0_0, 0, 1;
    %delay 10000, 0;
    %set/v v012BDAC8_0, 1, 1;
    %delay 10000, 0;
    %set/v v012BDAC8_0, 0, 1;
    %delay 10000, 0;
    %set/v v012BDB78_0, 0, 1;
    %set/v v012BDBD0_0, 1, 1;
    %delay 5000, 0;
    %set/v v012BDB78_0, 1, 1;
    %set/v v012BDBD0_0, 0, 1;
    %delay 10000, 0;
    %set/v v012BDAC8_0, 1, 1;
    %delay 10000, 0;
    %set/v v012BDAC8_0, 0, 1;
    %delay 50000, 0;
